{
  "name": "tinder-autopilot",
  "version": "3.0.0",
  "description": "Don't waste any more time doing manual tasks on Tinder. Autopilot will do it for you.",
  "main": "src/index.js",
  "packageManager": "pnpm@11.1.2",
  "repository": "https://github.com/isyuricunha/tinder-autopilot.git",
  "author": "Matthew <info@mgates.me>",
  "license": "MIT",
  "scripts": {
    "major": "dotenv release-it -- major --ci",
    "minor": "dotenv release-it -- minor --ci",
    "patch": "dotenv release-it -- patch --ci",
    "start": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "lint": "eslint src/**/*.js",
    "lint:firefox": "web-ext lint --source-dir dist-firefox",
    "package:firefox": "pnpm run build && node scripts/package-firefox.js",
    "test": "node --test test/**/*.test.js",
    "verify:firefox": "pnpm test && pnpm run lint && pnpm run build && pnpm run lint:firefox"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "ajv": "^8.20.0",
    "babel-loader": "^10.1.1",
    "bestzip": "^2.2.3",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "invariant": "^2.2.4",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "web-ext": "10.3.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ]
}
