{
  "name": "Autopilot for Tinder",
  "short_name": "Tinder Auto",
  "homepage_url": "https://github.com/isyuricunha/tinder-autopilot/",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Don't waste any more time doing manual tasks on Tinder. Autopilot will do it for you.",
  "manifest_version": 2,
  "version": "3.0.0",
  "author": "isyuricunha",
  "browser_specific_settings": {
    "gecko": {
      "id": "@tinder-autopilot.isyuricunha",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["personalCommunications", "websiteContent"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": ["bg.js"],
    "persistent": false
  },
  "permissions": [
    "storage",
    "https://api.gotinder.com/*",
    "https://*.gotinder.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "js": ["main.js"],
      "matches": ["https://tinder.com/*", "https://*.gotinder.com/*"]
    }
  ]
}
